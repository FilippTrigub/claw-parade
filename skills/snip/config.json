{
  "input_dir": "./input",
  "output_dir": "./output",
  "segments": [{"source": "video.mp4", "start": 0, "end": 60}],
  "output_fps": 30,
  "auto_detect": {
    "enabled": true,
    "mode": "adaptive",
    "min_scene_duration": 1.0,
    "max_scene_duration": 10.0
  },
  "transcription": {
    "enabled": true,
    "fallback_to_adaptive": true,
    "min_segment_duration": 1.0,
    "max_segment_duration": 30.0
  }
}
